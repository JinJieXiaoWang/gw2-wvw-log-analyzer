# =============================================================================
# GW2 WVW Log Analyzer - 环境变量配置示例
# =============================================================================
# 复制此文件为 .env 并根据环境修改对应值
# 所有配置项均可通过环境变量覆盖，无需修改代码
# =============================================================================

# ------------------------------------
# 应用基础配置
# ------------------------------------
VITE_APP_NAME=GW2 WVW日志分析
VITE_APP_VERSION=1.0.0
VITE_DEBUG=true

# ------------------------------------
# API 配置
# ------------------------------------
VITE_API_BASE_URL=http://localhost:8000/api
VITE_API_TIMEOUT=30000
VITE_UPLOAD_TIMEOUT=300000
VITE_API_RETRY_ATTEMPTS=3
VITE_API_RETRY_DELAY=1000
VITE_TOKEN_MONITOR_INTERVAL=30000
VITE_NOTIFICATION_POLL_INTERVAL=30000

# ------------------------------------
# Mock 配置
# ------------------------------------
VITE_MOCK_ENABLED=false
VITE_MOCK_DELAY=500

# ------------------------------------
# 缓存配置（毫秒）
# ------------------------------------
VITE_CACHE_PROFESSION_TTL=300000
VITE_CACHE_DICT_TTL=600000
VITE_CACHE_API_TTL=300000
VITE_CACHE_REQUEST_TTL=300000

# ------------------------------------
# 分页配置
# ------------------------------------
VITE_DEFAULT_PAGE_SIZE=20
VITE_MAX_PAGE_SIZE=100

# ------------------------------------
# 轮询配置（毫秒）
# ------------------------------------
VITE_POLLING_INTERVAL=2000
VITE_MAX_POLL_ATTEMPTS=30

# ------------------------------------
# 防抖配置（毫秒）
# ------------------------------------
VITE_DEBOUNCE_TABLE_SORT=300
VITE_DEBOUNCE_SEARCH=500
VITE_DEBOUNCE_RESIZE=250

# ------------------------------------
# UI 配置
# ------------------------------------
VITE_TOAST_LIFE=3000
VITE_TOAST_ERROR_LIFE=5000
VITE_MOBILE_BREAKPOINT=768
VITE_TABLET_BREAKPOINT=1024
VITE_DIALOG_MAX_WIDTH=640
VITE_MOBILE_DIALOG_WIDTH=95vw

# ------------------------------------
# 文件上传配置
# ------------------------------------
VITE_SUPPORTED_FORMATS=.zevtc
VITE_MAX_FILE_SIZE=104857600

# ------------------------------------
# 导出配置
# ------------------------------------
VITE_EXCEL_MAX_ROWS=10000
VITE_CSV_MAX_ROWS=50000

# ------------------------------------
# 功能开关
# ------------------------------------
VITE_ENABLE_AI=true
VITE_ENABLE_EXPORT=true
VITE_ENABLE_BUILD_PARSER=true
VITE_ENABLE_SKILL_ANALYSIS=true
VITE_ENABLE_ATTENDANCE=true
VITE_ENABLE_DASHBOARD=true
VITE_ENABLE_REALTIME=false

# ------------------------------------
# 主题配置
# ------------------------------------
VITE_THEME_MODE=dark
VITE_THEME_PRIMARY=#165DFF

# ------------------------------------
# 存储配置
# ------------------------------------
VITE_STORAGE_PREFIX=gw2_wvw_
VITE_TOKEN_KEY=token
VITE_TOKEN_EXPIRE=86400000
VITE_REFRESH_TOKEN_KEY=refresh_token

# ------------------------------------
# 构建信息（CI/CD 自动注入）
# ------------------------------------
VITE_BUILD_DATE=
VITE_COMMIT_HASH=
