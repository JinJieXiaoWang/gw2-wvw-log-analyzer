+    Necromancer: '姝?, Ranger: '娓?, Revenant: '榄?, Warrior: '鎴?
+  }
+  return map[prof] || prof.charAt(0)
+}
+
+const subRoleLabel = (sub: string): string => {
+  const map: Record<string, string> = { boon: '澧炵泭', heal: '娌荤枟', tank: '鎵夸激', cc: '鍓婃帶' }
+  return map[sub] || sub
+}
