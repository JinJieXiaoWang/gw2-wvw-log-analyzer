+import buildApi from '@/api/build/build';
+
+
+// Toast 鏈嶅姟
+const toast = useToast();
+
+// 鐘舵€?+const buildCode = ref('');
+const isParsing = ref(false);
+const parseError = ref('');
+const parsedData = ref<any>(null);
+const showSaveDialog = ref(false);
+const showImportDialog = ref(false);
+
+// 璁＄畻灞炴€э細鑾峰彇绮捐嫳鐗归暱鍚嶇О
+const eliteSpecName = computed(() => {
+  if (!parsedData.value?.specializations) return '';
+  const eliteSpec = parsedData.value.specializations.find(spec => spec.is_elite);
+  return eliteSpec?.name_cn || '';
+});
+
+// 鑱屼笟棰滆壊鏄犲皠
+const getProfessionColor = (profession: string) => {
+  const colors: Record<string, string> = {
+    Warrior: '#E85D04',
+    Guardian: '#FAA307',
+    Revenant: '#9D4EDD',
+    Ranger: '#06D6A0',
+    Engineer: '#7B8FA1',
+    Necromancer: '#8D0801',
+    Mesmer: '#4361EE',
+    Elementalist: '#FF6B6B'
+  };
+  return colors[profession] || '#6C757D';
+};
+
+// 鑾峰彇鑱屼笟棣栧瓧姣?+const getProfessionInitial = (profession: string) => {
+  return profession.charAt(0).toUpperCase();
+};
+
+// 娓呯悊鍥炬爣URL锛堢Щ闄ゅ彲鑳界殑寮曞彿鍜岀┖鏍硷級
+const cleanIconUrl = (iconUrl: string): string => {
+  if (!iconUrl) return '';
+  return iconUrl.trim().replace(/^[`'"]+|[`'"]+$/g, '');
+};
+
+// 瑙ｆ瀽Build浠ｇ爜
+const handleParseBuildCode = async () => {
+  if (!buildCode.value.trim()) {
+    parseError.value = '璇疯緭鍏uild浠ｇ爜';
+    return;
+  }
+
+  // 楠岃瘉浠ｇ爜鏍煎紡
+  const codePattern = /^\[&[A-Za-z0-9+/=]+\]$/;
+  if (!codePattern.test(buildCode.value.trim())) {
+    parseError.value = 'Build浠ｇ爜鏍煎紡涓嶆纭紝搴斾负 [&...] 鏍煎紡';
+    return;
+  }
+
+  isParsing.value = true;
+  parseError.value = '';
+
+  try {
+    const result = await buildApi.parseBuildCode(buildCode.value.trim());
+
+    if (result) {
+      parsedData.value = result;
+      toast.add({
+        severity: 'success',
+        summary: '瑙ｆ瀽鎴愬姛',
+        detail: 'Build浠ｇ爜瑙ｆ瀽瀹屾垚',
+        life: 3000
+      });
+    } else {
+      parseError.value = '瑙ｆ瀽澶辫触锛岃绋嶅悗閲嶈瘯';
+    }
+  } catch (error) {
+    console.error('瑙ｆ瀽Build浠ｇ爜澶辫触:', error);
+    parseError.value = error instanceof Error ? error.message : '瑙ｆ瀽澶辫触';
+    toast.add({
+      severity: 'error',
+      summary: '瑙ｆ瀽澶辫触',
+      detail: parseError.value,
+      life: 5000
+    });
+  } finally {
+    isParsing.value = false;
+  }
+};
+
+// 娓呯┖浠ｇ爜
+const handleClearCode = () => {
+  buildCode.value = '';
+  parsedData.value = null;
+  parseError.value = '';
+};
+
+// 瀵煎叆Build浠ｇ爜
+const handleImportBuildCode = (code: string) => {
+  buildCode.value = code;
+  showImportDialog.value = false;
+};
+
+// 淇濆瓨Build
+const handleSaveBuild = async (buildData: any) => {
+  try {
+    await buildApi.saveBuild(buildData);
+    showSaveDialog.value = false;
+    toast.add({
+      severity: 'success',
+      summary: '淇濆瓨鎴愬姛',
+      detail: 'Build閰嶇疆宸蹭繚瀛?,
+      life: 3000
+    });
+  } catch (error) {
+    console.error('淇濆瓨Build澶辫触:', error);
+    toast.add({
+      severity: 'error',
+      summary: '淇濆瓨澶辫触',
+      detail: error instanceof Error ? error.message : '淇濆瓨澶辫触',
+      life: 5000
+    });
+  }
+};
+
+// 澶嶅埗Build浠ｇ爜
+const handleCopyBuildCode = async () => {
+  if (!buildCode.value) return;
+
+  try {
+    await navigator.clipboard.writeText(buildCode.value);
+    toast.add({
+      severity: 'success',
+      summary: '澶嶅埗鎴愬姛',
+      detail: 'Build浠ｇ爜宸插鍒跺埌鍓创鏉?,
+      life: 2000
+    });
+  } catch (error) {
+    console.error('澶嶅埗澶辫触:', error);
+    toast.add({
+      severity: 'error',
+      summary: '澶嶅埗澶辫触',
+      detail: '鏃犳硶澶嶅埗鍒板壀璐存澘',
+      life: 3000
+    });
+  }
+};
+</script>
