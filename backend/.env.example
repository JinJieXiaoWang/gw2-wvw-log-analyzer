# =============================================================================
# GW2 WvW 日志系统 - 生产环境配置示例
# 域名: gw2-log-analyzer.top
# 更新日期: 2026-05-05
# =============================================================================
# 
# 使用说明：
# 1. 复制此文件为 .env:  cp .env.example .env
# 2. 修改所有标记为 【必填】 的项
# 3. 生产环境务必设置强密码和强 SECRET_KEY
# 4. 切勿将 .env 提交到版本控制
#
# =============================================================================

# =========================================
# 应用配置 【必填】
# =========================================
APP_NAME=GW2 WvW日志系统
DEBUG=False
# SECRET_KEY 必须是至少32个字符的随机字符串，用于 JWT/Session 签名
# 生成命令: openssl rand -base64 32
SECRET_KEY=change-me-to-a-random-string-at-least-32-characters-long
LOG_LEVEL=INFO

# =========================================
# 数据库配置 【必填】
# =========================================

# 数据库类型（sqlite/mysql/postgresql）
DB_TYPE=mysql

# --- MySQL配置（生产环境推荐）---
MYSQL_HOST=db
MYSQL_PORT=3306
MYSQL_USER=gw2
# 安全提示：生产环境必须使用强密码
MYSQL_PASSWORD=your_secure_mysql_password_here
MYSQL_DATABASE=gw2
MYSQL_CHARSET=utf8mb4
MYSQL_POOL_SIZE=10
MYSQL_MAX_OVERFLOW=20

# --- SQLite配置（仅开发/测试使用）---
# SQLITE_DB_PATH=./database/app.db

# --- PostgreSQL配置（可选）---
# POSTGRESQL_HOST=localhost
# POSTGRESQL_PORT=5432
# POSTGRESQL_USER=postgres
# POSTGRESQL_PASSWORD=your_password
# POSTGRESQL_DATABASE=gw2_log_system

# =========================================
# 数据库高级配置
# =========================================
AUTO_CREATE_TABLES=True
AUTO_MIGRATE=False
POOL_PRE_PING=True
POOL_RECYCLE=3600

# =========================================
# 文件存储配置
# =========================================
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=104857600

# =========================================
# 管理员初始化配置 【必填】
# =========================================
# 预置管理员（用户名固定为 admin）的初始密码。
# 生产环境必须设置强密码，Docker 部署时会自动同步到数据库。
# 若修改此密码并重启容器，ADMIN_PASSWORD_SYNC=true 会自动更新数据库中的密码。
ADMIN_INITIAL_PASSWORD=your_secure_admin_password_here

# 是否强制同步预置管理员密码（解决 Docker 重新部署后密码不一致问题）
# 生产环境 Docker 部署建议保持 true
ADMIN_PASSWORD_SYNC=true

# =========================================
# CORS 配置（自动包含域名，一般无需修改）
# =========================================
# BACKEND_CORS_ORIGINS=["https://gw2-log-analyzer.top","http://gw2-log-analyzer.top"]

# =========================================
# AI配置（可选）
# =========================================
AI_ENABLED=False
AI_MODEL_PROVIDER=deepseek
# DEEPSEEK_API_KEY=your_deepseek_api_key
# OPENAI_API_KEY=your_openai_api_key
# QWEN_API_KEY=your_qwen_api_key

# =========================================
# Uvicorn 配置（Docker 环境一般无需修改）
# =========================================
# UVICORN_HOST=0.0.0.0
# UVICORN_PORT=8000
# UVICORN_WORKERS=2

# =========================================
# 内存优化配置（2026-05-06新增）
# =========================================
# 内存监控配置 - 用于防止OOM
# 单次请求内存增量阈值（MB），超过记录警告
MEMORY_DELTA_THRESHOLD_MB=100
# 内存软限制（MB），超过开始记录警告
MEMORY_RSS_SOFT_LIMIT_MB=1536
# 内存硬限制（MB），超过记录错误
MEMORY_RSS_HARD_LIMIT_MB=2048
# 内存严重限制（MB），超过拒绝新请求
MEMORY_RSS_CRITICAL_LIMIT_MB=2560
# 自动GC触发阈值（MB）
AUTO_GC_THRESHOLD_MB=800

# 缓存配置
CACHE_MAX_ITEMS=1000
CACHE_MAX_SIZE_MB=200
CACHE_DEFAULT_TTL_SECONDS=3600
