# =============================================================================
# GW2 WvW 日志系统 - 开发环境配置
# =============================================================================

# 应用配置
APP_NAME=GW2 WvW日志系统
DEBUG=True
SECRET_KEY=dev-secret-key-for-development-only-32-chars-min
LOG_LEVEL=DEBUG

# 数据库配置（已切换至 MySQL）
DB_TYPE=mysql
MYSQL_HOST=192.168.1.26
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=123456
MYSQL_DATABASE=gw2_log_system
MYSQL_CHARSET=utf8mb4

# 数据库高级配置
AUTO_CREATE_TABLES=True
AUTO_MIGRATE=False

# 文件存储配置
UPLOAD_DIR=./uploads


# AI配置
AI_ENABLED=true
AI_MODEL_PROVIDER=deepseek

# DeepSeek配置
DEEPSEEK_API_KEY=sk-b27080b34b7d418e83c19261cd8a50e2
DEEPSEEK_API_BASE=https://api.deepseek.com/anthropic
DEEPSEEK_MODEL=deepseek-v4-pro

# OpenAI配置（备用）
OPENAI_API_KEY=
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_MODEL=gpt-3.5-turbo

# 管理员初始化配置
ADMIN_INITIAL_PASSWORD=admin123
ADMIN_PASSWORD_SYNC=true

# CORS 配置

# 内存优化配置
MEMORY_DELTA_THRESHOLD_MB=100
MEMORY_RSS_SOFT_LIMIT_MB=1536
MEMORY_RSS_HARD_LIMIT_MB=2048
MEMORY_RSS_CRITICAL_LIMIT_MB=2560
AUTO_GC_THRESHOLD_MB=800

# 缓存配置
CACHE_MAX_ITEMS=1000
CACHE_MAX_SIZE_MB=200
CACHE_DEFAULT_TTL_SECONDS=3600
