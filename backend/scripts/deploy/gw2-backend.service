# GW2 WvW 日志系统 - Systemd 服务配置
# 安装: sudo cp gw2-backend.service /etc/systemd/system/
# 启用: sudo systemctl daemon-reload && sudo systemctl enable --now gw2-backend

[Unit]
Description=GW2 WvW 日志系统后端 API
After=network.target mysql.service
Wants=mysql.service

[Service]
Type=simple
User=gw2
Group=gw2
WorkingDirectory=/opt/gw2-backend
Environment="PATH=/opt/gw2-backend/venv/bin:/usr/local/bin:/usr/bin:/bin"

# ==================== 应用配置 ====================
Environment="APP_NAME=GW2 WvW日志系统"
Environment="APP_VERSION=1.0.0"
Environment="DEBUG=False"
Environment="API_PREFIX=/api/v1"
# 安全提示：生产环境必须设置强密钥（至少32位随机字符串）
# 生成方式: openssl rand -base64 32
Environment="SECRET_KEY=CHANGE_ME_TO_A_RANDOM_STRING_AT_LEAST_32_CHARS_LONG"
Environment="BACKEND_CORS_ORIGINS=[\"http://localhost:5173\",\"http://localhost:3000\"]"

# ==================== 日志配置 ====================
Environment="LOG_LEVEL=INFO"
Environment="LOG_FILE=/opt/gw2-backend/logs/app.log"

# ==================== 文件上传配置 ====================
Environment="UPLOAD_DIR=/opt/gw2-backend/uploads"
Environment="MAX_UPLOAD_SIZE=104857600"

# ==================== 管理员配置 ====================
# 若设置，系统使用此值作为 admin 初始密码；若留空，首次启动时自动生成随机密码
# Environment="ADMIN_INITIAL_PASSWORD=your_secure_admin_password"

# ==================== 存储管理配置 ====================
Environment="FILE_RETENTION_DAYS=30"
Environment="MAX_STORAGE_SIZE=10737418240"
Environment="STORAGE_WARNING_THRESHOLD=80.0"
Environment="AUTO_CLEANUP_ENABLED=True"
Environment="AUTO_CLEANUP_INTERVAL=24"
Environment="KEEP_RAW_FILE_AFTER_PARSE=True"
Environment="FILE_COMPRESSION_ENABLED=False"

# ==================== 数据库配置 ====================
# 数据库类型: sqlite / mysql / postgresql
Environment="DB_TYPE=mysql"

# --- SQLite (如果选择 sqlite) ---
Environment="SQLITE_DB_PATH=/opt/gw2-backend/database/app.db"

# --- MySQL (如果选择 mysql) ---
Environment="MYSQL_HOST=127.0.0.1"
Environment="MYSQL_PORT=3306"
Environment="MYSQL_USER=gw2"
Environment="MYSQL_PASSWORD=CHANGE_ME_TO_STRONG_MYSQL_PASSWORD"
Environment="MYSQL_DATABASE=gw2_log_system"
Environment="MYSQL_CHARSET=utf8mb4"
Environment="MYSQL_POOL_SIZE=10"
Environment="MYSQL_MAX_OVERFLOW=20"
Environment="MYSQL_LOCK_WAIT_TIMEOUT=30"

# --- PostgreSQL (如果选择 postgresql) ---
# Environment="POSTGRESQL_HOST=127.0.0.1"
# Environment="POSTGRESQL_PORT=5432"
# Environment="POSTGRESQL_USER=gw2"
# Environment="POSTGRESQL_PASSWORD=CHANGE_ME_TO_STRONG_POSTGRESQL_PASSWORD"
# Environment="POSTGRESQL_DATABASE=gw2_log_system"
# Environment="POSTGRESQL_POOL_SIZE=10"
# Environment="POSTGRESQL_MAX_OVERFLOW=20"

# --- 连接池通用配置 ---
Environment="POOL_PRE_PING=True"
Environment="POOL_RECYCLE=300"
Environment="CONNECT_TIMEOUT=10"

# --- 自动建表 ---
Environment="AUTO_CREATE_TABLES=True"
Environment="AUTO_MIGRATE=False"

# ==================== AI 配置 (可选) ====================
Environment="AI_ENABLED=False"
Environment="AI_MODEL_PROVIDER=deepseek"
# Environment="DEEPSEEK_API_KEY=your_deepseek_api_key"
# Environment="OPENAI_API_KEY=your_openai_api_key"
# Environment="QWEN_API_KEY=your_qwen_api_key"

ExecStart=/opt/gw2-backend/venv/bin/uvicorn main:app --host 127.0.0.1 --port 8000 --workers 2
ExecReload=/bin/kill -s HUP $MAINPID
ExecStop=/bin/kill -s TERM $MAINPID

Restart=on-failure
RestartSec=5

# 资源限制
LimitNOFILE=65535
LimitNPROC=4096

[Install]
WantedBy=multi-user.target
